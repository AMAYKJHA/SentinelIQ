# ── Core ──
DEBUG=True
APP_NAME=SentinelIQ
APP_BASE_URL=http://localhost:8000
FRONTEND_BASE_URL=http://localhost:3000

# Strong random secret. Generate with:  python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=replace-me-with-a-strong-random-secret

# ── Database ──
DATABASE_URL=postgresql+psycopg://user:password@host:5432/dbname

# ── JWT ──
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=20160   # 14 days

# ── CORS ──
# JSON list. Use the exact frontend origin(s); "*" will NOT work with credentialed cookies.
ALLOW_ORIGINS=["http://localhost:3000"]

# ── Redis (Upstash / managed Redis with TLS) ──
REDIS_HOST=your-redis-host
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password

# ── Email (Brevo HTTP API) ──
BREVO_API_KEY=your-brevo-api-key
BREVO_URL=https://api.brevo.com/v3/smtp/email
BREVO_FROM_NAME=SentinelIQ
BREVO_FROM_EMAIL=noreply@yourdomain.com

# ── Geo / IP enrichment (ipinfo.io) ──
IP_INFO_KEY=your-ipinfo-token
IP_INFO_URL=https://ipinfo.io

# ── Velocity (sliding window, seconds) ──
VELOCITY_WINDOW_SECONDS=60
USER_MAX_ATTEMPTS=5
IP_MAX_ATTEMPTS=20
USER_IP_MAX_ATTEMPTS=10

# ── Risk weights (rule-based signals) ──
VELOCITY_WEIGHT=0.30
GEO_WEIGHT=0.35
DEVICE_WEIGHT=0.20
BEHAVIORAL_WEIGHT=0.15

# Final blend of rule-based vs ML score (ML stays 0 until the model is wired in)
RULE_BASE_WEIGHT=1.0
ML_WEIGHT=0.0

# ── Risk bands ──
RISK_ALLOW_MAX=0.35
RISK_BLOCK_MIN=0.70
TRUSTED_DEVICE_HARD_BLOCK=0.85

# ── Geo ──
GEO_MAX_SPEED_KMH=900
GEO_HOME_RADIUS_KM=500
GEO_HISTORY_SIZE=10

# ── Device trust ──
TRUSTED_DEVICE_DAYS=30
DEVICE_SIMILARITY_THRESHOLD=0.66

# ── MFA / OTP ──
OTP_LENGTH=6
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5
MFA_CHALLENGE_TTL_SECONDS=600
MAGIC_LINK_TTL_SECONDS=86400

# ── Behavioral baseline ──
BEHAVIOR_EWMA_ALPHA=0.2
BEHAVIOR_MIN_LOGINS_FOR_BASELINE=5
BEHAVIOR_ZSCORE_FLAG=3.0
